#!/usr/bin/env python3
"""{{ description }}"""

import argparse
import sys
from os.path import basename


# ---------------------------------------------------------------------------
# Subcommand handlers
# ---------------------------------------------------------------------------

def cmd_run(args: argparse.Namespace) -> None:
    """Handle the 'run' subcommand."""
    if args.verbose:
        print(f"[debug] args={args}", file=sys.stderr)
    print(f"Running with target: {args.target}")


def cmd_status(args: argparse.Namespace) -> None:
    """Handle the 'status' subcommand."""
    print("Status: OK")


# ---------------------------------------------------------------------------
# CLI definition
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog=basename(sys.argv[0]),
        description="{{ description }}",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    parser.add_argument("-v", "--verbose", action="store_true", help="Verbose output")

    subparsers = parser.add_subparsers(dest="command", required=True, metavar="<command>")

    # run
    run_parser = subparsers.add_parser("run", help="Run the main operation")
    run_parser.add_argument("target", help="Target to operate on")
    run_parser.add_argument("--dry-run", action="store_true", help="Simulate without making changes")
    run_parser.set_defaults(func=cmd_run)

    # status
    status_parser = subparsers.add_parser("status", help="Show current status")
    status_parser.set_defaults(func=cmd_status)

    return parser


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
